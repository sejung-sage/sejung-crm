# ============================================================
# 세정-CRM ETL · 환경변수 샘플
# 실제 값은 scripts/etl/.env (gitignore) 에 넣을 것.
# ============================================================

# ── 아카(Aca2000) MSSQL 4개 분원 공통 ────────────────────────
# 비밀번호는 절대 채팅·코드·이메일 평문 X.
ACA_MSSQL_USER=sejung_user
ACA_MSSQL_PASSWORD=

# ── Supabase (Service Role 사용 — RLS 우회) ─────────────────
# server.ts 의 createSupabaseServiceClient 와 동일 키.
# .env.local 의 SUPABASE_SECRET_KEY 와 같은 값.
SUPABASE_URL=https://gnqrdgjgapwbofonowxd.supabase.co
SUPABASE_SECRET_KEY=

# ── ETL 실행 옵션 ───────────────────────────────────────────
# DRY_RUN=1 이면 Supabase 에 INSERT 하지 않고 변환 결과만 출력.
DRY_RUN=1
# 마이그레이션 1회 실행 시 한 분원만 시범 (방배가 가장 작아서 4051건):
ONLY_BRANCH=
# 가능한 값: 80205(방배), 78031(대치), 85489(반포), 85491(송도)
