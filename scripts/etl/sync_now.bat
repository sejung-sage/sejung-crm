@echo off
REM ============================================================
REM 세정-CRM ETL · 수동 즉시 동기화 (운영자 더블클릭용)
REM ------------------------------------------------------------
REM run_all.bat 을 호출하지만:
REM   - 콘솔 창에 진행 상황을 실시간으로 표시
REM   - 작업 끝나도 자동으로 닫히지 않음 (결과 확인 가능)
REM
REM 자동 스케줄과 충돌 가능성:
REM   본 스크립트는 작업 스케줄러의 `IgnoreNew` 정책과 별개로 동작.
REM   거의 동시에 자동 실행이 시작되면 두 인스턴스가 같은 데이터를
REM   UPSERT 할 수 있는데, ETL 스크립트가 idempotent 라 결과 영향 없음.
REM ============================================================
chcp 65001 >nul
title 세정학원 CRM · 수동 동기화

cd /d "%~dp0\..\.."

echo.
echo ============================================================
echo   세정학원 CRM · 수동 ETL 동기화
echo   (Aca2000 → Supabase, 약 5~15분 소요)
echo ============================================================
echo.
echo 시작: %DATE% %TIME%
echo.

call scripts\etl\run_all.bat

echo.
echo ============================================================
echo   수동 동기화 종료. 위 로그를 확인한 뒤 아무 키나 누르세요.
echo ============================================================
pause >nul
